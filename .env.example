# Mock test admin runtime credentials
MOCK_TEST_ADMIN_EMAIL=admin@example.com
MOCK_TEST_ADMIN_PASSWORD=replace-with-strong-password

# Supabase frontend auth configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Student auth flow mode: otp (preferred) or link
VITE_AUTH_EMAIL_VERIFICATION_MODE=otp

# Enable booking modal to trigger student registration service
VITE_ENABLE_REGISTRATION_FLOW=true

# Redirect paths used in Supabase emails
VITE_AUTH_REDIRECT_PATH_CREATE_PASSWORD=/student/create-password
VITE_AUTH_REDIRECT_PATH_RESET_PASSWORD=/student/reset-password

# Frontend Zoom values (safe to expose in browser if they are meeting metadata)
VITE_PADMA_ZOOM_PERSONAL_MEETING_ID=369 394 5085
VITE_PADMA_ZOOM_JOIN_LINK=https://us04web.zoom.us/j/3693945085?pwd=HgWaomMcXRE29FnpctaPMmiHXbwAa8.1
VITE_PADMA_ZOOM_PASSCODE=Configured in join URL

# Backend Zoom secrets (set these in Supabase secrets / server env, not frontend)
ZOOM_ACCOUNT_ID=replace-with-zoom-account-id
ZOOM_CLIENT_ID=replace-with-zoom-s2s-client-id
ZOOM_CLIENT_SECRET=replace-with-zoom-s2s-client-secret
ZOOM_HOST_KEY=replace-with-host-key
